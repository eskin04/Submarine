  - m_Id: 1845267677224960
    m_Localized: Biyolojik
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973696
    m_Localized: Mekanik
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973697
    m_Localized: Parlak
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973698
    m_Localized: "Patlay\u0131c\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973699
    m_Localized: "De\u011Ferli"
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973700
    m_Localized: Manyetik
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973701
    m_Localized: Anormal
    m_Metadata:
      m_Items: []
  - m_Id: 1845267714973702
    m_Localized: "Se\xE7ilen 3. cisim ise {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973703
    m_Localized: "T\xFCm {X} cisimleri {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973704
    m_Localized: "Radar i\xE7 merkezindeki t\xFCm {Y} cisimleri {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973705
    m_Localized: "Radarda en yava\u015F yakla\u015Fan cismi {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973706
    m_Localized: "Se\xE7ilen ilk cisim ise {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973707
    m_Localized: "Denizalt\u0131 su seviyesi %50'den y\xFCksekse Patlay\u0131c\u0131
      cisimleri {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973708
    m_Localized: "Radarda birden fazla cisim varsa ve aralar\u0131ndaki en h\u0131zl\u0131
      cisim {X} DE\u011E\u0130LSE {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973709
    m_Localized: "Cisim 3m/s'den h\u0131zl\u0131ysa ve Patlay\u0131c\u0131 VEYA Mekanik
      ise {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973710
    m_Localized: "{X} cisimleri SADECE radar i\xE7 merkezine girdiklerinde {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973711
    m_Localized: "Cisim, i\u015Flem g\xF6ren bir \xF6nceki cisim ile en az bir ortak
      kategoriye sahipse {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973712
    m_Localized: "Su seviyesi %25'in alt\u0131ndaysa, en h\u0131zl\u0131 yakla\u015Fan
      cismi {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973713
    m_Localized: "Su seviyesi %25'in alt\u0131ndaysa {X} cisimleri {ACTION}, %75'in
      \xFCst\xFCndeyse {Y} cisimlerini {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973714
    m_Localized: "Daha \xF6nce {ACTION} eylemi uygulanan cisim {X} ise, s\u0131radaki
      ilk {Y} cismi {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973715
    m_Localized: "Cisim \xF6nceki \u0130K\u0130 cisimle ortak bir kategoriye sahipse
      VE en az bir farkl\u0131 kategorisi daha varsa {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973716
    m_Localized: "Yok edilen bir \xF6nceki cisim {X} ise, mevcut cismi {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973717
    m_Localized: "En h\u0131zl\u0131 yakla\u015Fan cisim {X} DE\u011E\u0130LSE {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973718
    m_Localized: Cisim HEM {X} HEM DE {Y} ise {ACTION}.
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973719
    m_Localized: Cisim {X} VEYA {Y} ise {ACTION}.
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973720
    m_Localized: Sadece tek bir kategoriye sahip olan cisimleri {ACTION}.
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973721
    m_Localized: "Cisim 4m/s'den yava\u015Fsa VE radar i\xE7 merkezindeyse {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973722
    m_Localized: "2m/s'den h\u0131zl\u0131 olan t\xFCm {X} cisimleri {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
  - m_Id: 1845267714973723
    m_Localized: "\xDC\xE7 kategoriye sahip olan cisimleri {ACTION}."
    m_Metadata:
      m_Items:
      - rid: 8544654921302540400
