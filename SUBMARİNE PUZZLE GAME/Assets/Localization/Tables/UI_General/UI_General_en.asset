  - m_Id: 1845267714973702
    m_Localized: '{ACTION} if it is the 3rd Processed object.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973703
    m_Localized: '{ACTION} all {X} objects'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973704
    m_Localized: '{ACTION} all {Y} objects currently in the inner radar.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973705
    m_Localized: '{ACTION} the slowest approaching object on the radar.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973706
    m_Localized: '{ACTION} if it is the 1st Processed object.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973707
    m_Localized: '{ACTION} Explosive objects if the submarine water level is above
      50%.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973708
    m_Localized: If there are multiple objects on the radar, {ACTION} the fastest
      one if it is NOT {X}
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973709
    m_Localized: '{ACTION} if the object is faster than 3m/s AND is Explosive OR
      Mechanical.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973710
    m_Localized: '{ACTION} {X} objects ONLY when they enter the inner radar.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973711
    m_Localized: '{ACTION} if the object shares at least one category with the previously
      acted object.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973712
    m_Localized: '{ACTION} the fastest approaching object if the water level is below
      25%.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973713
    m_Localized: If water level is below 25%, {ACTION} {X}. If above 75%, {ACTION}
      {Y}.
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973714
    m_Localized: If the previously {ACTION} object was {X}, {ACTION} the next {Y}
      object.
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973715
    m_Localized: '{ACTION} if the object shares a category with the last TWO objects
      AND has at least one different category.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973716
    m_Localized: '{ACTION} the current object if the previously DESTROYED object
      was {X}.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973717
    m_Localized: '{ACTION} the fastest approaching object if it is NOT {X}.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973718
    m_Localized: '{ACTION} the object if it is BOTH {X} AND {Y}.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973719
    m_Localized: '{ACTION} the object if it is {X} OR {Y}.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973720
    m_Localized: '{ACTION} objects that have only a single category.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973721
    m_Localized: '{ACTION} if the object is slower than 4m/s AND is in the inner
      radar.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973722
    m_Localized: '{ACTION} all {X} objects that are faster than 2m/s.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
  - m_Id: 1845267714973723
    m_Localized: '{ACTION} objects that have three categories.'
    m_Metadata:
      m_Items:
      - rid: 8544654921302540399
